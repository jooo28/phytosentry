# PhytoSentry backend environment configuration
# Local dev default:
PHYTOSENTRY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
PHYTOSENTRY_FRONTEND_URL=http://localhost:5173

# Production data storage
# On Render persistent disk, set PHYTOSENTRY_DATA_DIR=/var/data
# This keeps SQLite DB, uploaded images, generated PDF reports, weather cache, chat history, and bookings persistent.
PHYTOSENTRY_DATA_DIR=backend
# Optional overrides; normally leave blank and use PHYTOSENTRY_DATA_DIR only.
# PHYTOSENTRY_DB_PATH=/var/data/phytosentry.db
# PHYTOSENTRY_UPLOAD_DIR=/var/data/uploads
# PHYTOSENTRY_REPORT_DIR=/var/data/reports

PHYTOSENTRY_SESSION_TTL_SECONDS=2592000
PHYTOSENTRY_WEATHER_CACHE_SECONDS=1800
PHYTOSENTRY_CLEANUP_MAX_AGE_DAYS=14
PHYTOSENTRY_RATE_WINDOW_SECONDS=60
PHYTOSENTRY_RATE_MAX_REQUESTS=120
PHYTOSENTRY_LOGIN_FAIL_WINDOW_SECONDS=900
PHYTOSENTRY_LOGIN_FAIL_MAX_ATTEMPTS=8

# Optional Bangla font for better Bangla PDF rendering
PHYTOSENTRY_BN_FONT=

# Optional SMTP for real password reset emails
PHYTOSENTRY_SMTP_HOST=
PHYTOSENTRY_SMTP_PORT=587
PHYTOSENTRY_SMTP_USER=
PHYTOSENTRY_SMTP_PASS=
PHYTOSENTRY_EMAIL_FROM=

# Local demo only: set 1 to show reset token in API response
PHYTOSENTRY_DEV_RESET_TOKEN=0

# Optional future chatbot AI integration (not required for current offline FAQ bot)
# PHYTOSENTRY_CHATBOT_AI_PROVIDER=openai
# PHYTOSENTRY_CHATBOT_AI_API_KEY=your_api_key_here

# Email/phone auth and verification
# Email verification works through SMTP above. Phone OTP is demo-queued by default.
# Set PHYTOSENTRY_DEV_OTP=1 for classroom/demo so OTP appears in API response.
# Set PHYTOSENTRY_DEV_OTP=0 before public production.
PHYTOSENTRY_DEV_OTP=1
PHYTOSENTRY_OTP_TTL_SECONDS=600

# Optional future real SMS gateway placeholders. Current build queues phone OTPs in the outbox table
# unless you connect these credentials inside send_sms_or_outbox().
PHYTOSENTRY_SMS_PROVIDER=
PHYTOSENTRY_SMS_API_KEY=
PHYTOSENTRY_SMS_SENDER_ID=PhytoSentry
